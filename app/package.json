    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "latest",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.0",
    "jsonrepair": "^3.13.3",
    "lucide-react": "^0.545.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.7",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
